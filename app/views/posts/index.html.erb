<% content_for :title, "Home" %>

<div class="max-w-2xl mx-auto w-full">

  <% if notice.present? %>
    <div class="mb-6 flex items-center gap-2 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 dark:border-green-900/30 dark:bg-green-950/20 dark:text-green-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <header class="mb-10 text-center">
    <h1 class="text-4xl !font-[Bricolage_Grotesque] font-semibold text-neutral-900 dark:text-white tracking-tight">
      Looking for an upcoming event?
    </h1>
    <p class="text-neutral-500 mt-2">Discover what's happening in your community</p>
  </header>

  <%# Sort by %>
  <%= form_with url: posts_path, method: :get, class: "w-full flex justify-end items-center gap-2 mb-4", data: { turbo_frame: "posts" } do |f| %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
      <path fill-rule="evenodd" d="M3.792 2.938A49.069 49.069 0 0 1 12 2.25c2.797 0 5.54.236 8.209.688a1.857 1.857 0 0 1 1.541 1.836v1.044a3 3 0 0 1-.879 2.121l-6.182 6.182a1.5 1.5 0 0 0-.439 1.061v2.927a3 3 0 0 1-1.658 2.684l-1.757.878A.75.75 0 0 1 9.75 21v-5.818a1.5 1.5 0 0 0-.44-1.06L3.13 7.938a3 3 0 0 1-.879-2.121V4.774c0-.897.64-1.683 1.542-1.836Z" clip-rule="evenodd" />
    </svg>

    <div class="w-full max-w-2xs">
      <%= select_tag :sort,
          options_for_select([
            ["Date posted", "date_posted"],
            ["Event date", "event_date"]
          ], params[:sort]),
          include_blank: "Sort by...",
          class: "w-full [&>*:first-child]:!cursor-pointer",
          data: {
            controller: "select",
            select_submit_on_change_value: true,
            select_dropdown_input_value: false, # Enable this to add a search input to the dropdown
            select_disable_typing_value: true
          } %>
    </div>
  <% end %>

  <div id="posts" class="space-y-8 w-full">
    <% @posts.each do |post| %>
      <%= render post %>
    <% end %>
  </div>
</div>
