<% content_for :title, @post.event_title %>
<%= render 'layouts/error' %>
<%= render 'layouts/notice' %>
<div class="mt-2 max-w-2xl mx-auto w-full h-full">
  <% if flash[:alert] %>
    <div class="flex items-center gap-2 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-900/30 dark:bg-red-950/20 dark:text-red-400">
      <%= flash[:alert] %>
    </div>
  <% end %>
  <div class="bg-[var(--post-background)] rounded-xl shadow-xs overflow-hidden border border-black/10 dark:border-white/10 w-2xl">
    <%# Header %>
    <div class="px-6 py-4 bg-[var(--post-background)] font-[Unbounded] border-b border-black/10 dark:border-white/10">
      <div class="flex items-center justify-between">
        <%# left of header %>
        <div class="flex items-center text-[var(--post-background)]">
          <% if @post.organizer&.avatar&.attached? %>
            <%= image_tag @post.organizer.avatar, class: "h-10 w-10 rounded-full object-cover", alt: "Author" %>
          <% else %>
            <div class="h-10 w-10 rounded-full bg-neutral-300 dark:bg-neutral-700 flex items-center justify-center text-sm font-bold text-neutral-600 dark:text-neutral-300">
              <%= @post.organizer&.username&.first&.upcase %>
            </div>
          <% end %>
          <div class="ml-3">
            <p class="text-md font-medium text-[var(--brand-black)]">@<%=@post.organizer.username%></p>
            <p class="text-sm font-light text-[var(--brand-black)]">
              <%= @post.updated_at.localtime.strftime('%B %e, %Y, %l:%M %P')%>
            </p>
          </div>
        </div>
        <%# right of header %>
        <div class = "flex items-center gap-4">
          <%# Event countdown %>
          <p class="w-fit bg-[var(--brand-blue)] italic font-light text-[var(--post-background)] text-xl px-3 rounded-2xl border">
            <%= event_countdown_text(@post.event_date)%>
          </p>
          <%# Share button %>
          <button type="button" class="text-[var(--brand-black)]" data-controller="clipboard"
            data-clipboard-text="<%= post_url(@post) %>"
            data-clipboard-success-message-value="Post link copied!"
            data-clipboard-show-tooltip-value="true">
            <svg class="size-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z" />
            </svg>
          </button>
        </div>
      </div>
    </div>
    <%# Main content %>
    <div class="px-6 py-4">
      <div class="flex flex-col gap-2 my-2">
        <%# Username %>
        <h3 class="text-2xl font-semibold text-[var(--brand-black)] dark:text-white break-words">
          <%=@post.organizer.username%> is hosting: <span class="px-1 underline decoration-solid underline-offset-4 decoration-[var(--brand-blue)]"><%=@post.event_title%></span>
        </h3>
        <%# Location info %>
        <div class="flex flex-row gap-2 text-[var(--brand-black)] font-medium dark:text-white break-words">
          <%# Icon %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
            <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
          </svg>
          <%# Location %>
          <h4 class="text-lg"><%=@post.location%></h4>
        </div>
        <%# Date info %>
        <div class="flex flex-row gap-2 text-[var(--brand-black)] font-medium">
          <%# Icon %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
            <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z" clip-rule="evenodd" />
          </svg>
          <%# Date %>
          <h4 class=""><%=format_date(@post.event_date)%></h4>
        </div>
        <%# Post content %>
        <p class="text-[var(--brand-black)] my-4 dark:text-neutral-300 text-md break-words">
          <%= @post.description %>
        </p>
        <%# requirements here if we have time... %>
      </div>
      <div class="px-4 py-4 sm:px-6">
        <%# Delete and Edit %>
        <div class="flex items-end justify-between pt-6 border-t border-[var(--grey-subtitle)] dark:border-white/5">
          <div class="flex gap-2">
            <% if @post.organizer == current_user %>
              <div class="flex items-end justify-between pt-6 border-t border-[var(--grey-subtitle)] dark:border-white/5">
                <div class="flex gap-2">
                  <%= link_to edit_post_path(@post), class: "px-4 py-2 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-neutral-200 dark:bg-neutral-700/50 dark:text-neutral-200 dark:hover:bg-neutral-700 transition-all" do %>
                    Edit Event
                  <% end %>
                </div>
                <%= button_to @post, method: :delete, data: { turbo_method: :delete, turbo_confirm: "This action cannot be undone. This will permanently delete your post and remove its respective data from our servers." },
              class: "px-4 py-2 text-sm font-semibold rounded-lg text-[var(--brand-orange)] hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-950/30 transition-all" do %>
                  Delete
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>