<div class="max-w-2xl mx-auto w-full h-full">
  <% if notice.present? %>
    <div class="mb-6 flex items-center rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 dark:border-green-900/30 dark:bg-green-950/20 dark:text-green-400 w-2xl">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-xs overflow-hidden border border-black/10 dark:border-white/10 w-2xl h-full flex flex-col">
    <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-900/50 border-t border-black/10 dark:border-white/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <img class="h-10 w-10 rounded-full" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Author">
            <div class="ml-3">
              <p class="text-md font-medium text-neutral-900 dark:text-white">@<%=@post.user.username%></p>
              <p class="text-sm text-neutral-500 dark:text-neutral-400">
                <%= local_time(@post.updated_at, format: '%B %e, %Y, %l:%M %P') %>
              </p>
            </div>
          </div>
          <button type="button" class="text-neutral-400 hover:text-neutral-500">
            <svg class="size-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z" />
            </svg>
          </button>
        </div>
      </div>
      <div class="px-6 py-4 flex-grow flex flex-col">
        <h3 class="text-2xl font-semibold text-neutral-900 dark:text-white mb-2 break-words">
          <%=@post.user.username%> is hosting: <%=@post.event_title%>
        </h3>
        <h4 class="text-xl font-medium text-neutral-900 dark:text-white mb-2 !font-[Bricolage_Grotesque] break-words">
          <div class = "italic"> at <%=@post.location%></div>
        </h4>
        <h5 class="mb-6">on <%=if @post.event_date != nil
                    @post.event_date.strftime('%B %d, %Y')
                  else
                    @post.event_date
                  end%></h5>
        <p class="text-neutral-700 dark:text-neutral-300 text-md mb-6 break-words whitespace-pre-line">
          <%=@post.description%>
        </p>

        <div class="flex flex-grow"></div>

        <%# Delete and Edit %>
        <div class="flex items-end justify-between pt-6 border-t border-black/5 dark:border-white/5">
        <div class="flex gap-2">
          <%= link_to edit_post_path(@post), class: "px-4 py-2 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-neutral-200 dark:bg-neutral-700/50 dark:text-neutral-200 dark:hover:bg-neutral-700 transition-all" do %>
            Edit Event
          <% end %>
        </div>
        
        <%= button_to @post, method: :delete, 
            form: { data: { confirm: "Are you sure?" } },
            class: "px-4 py-2 text-sm font-semibold rounded-lg text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-950/30 transition-all" do %>
          Delete
        <% end %>
      </div>
      </div>
    </div>
  </div>
</div>